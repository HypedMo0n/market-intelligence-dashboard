# AI Trading Intelligence Platform local configuration.
# Copy to .env.local for Next.js. Never commit real secrets.

# MT5 bridge -> API ingest secret.
MT5_INGEST_SECRET=
VERCEL_APP_URL=http://localhost:3000

# Supabase persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional AI provider. The app works without these via local educational fallback.
OPENAI_API_KEY=
OPENAI_MODEL=
