# Your Trading Intelligence local configuration.
# Copy to .env.local for Next.js. Never commit real secrets.

# MT5 bridge -> API ingest secret.
MT5_INGEST_SECRET=
VERCEL_APP_URL=http://localhost:3000

# Supabase persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# FRED macro data. If unset, /api/macro/fred returns a 503 unavailable fallback.
FRED_API_KEY=

# Optional AI providers. The app works without these via local educational fallback.
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional dynamic market-data provider for non-MT5 assets.
TWELVE_DATA_API_KEY=
